{
	"compilerOptions": {
		"lib": ["ESNext"],

		"module": "esnext",
		"moduleResolution": "node",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"isolatedModules": true,

		"target": "esnext",
		"outDir": "./dist",
		"declaration": true,
		"removeComments": true,
		"sourceMap": true,
		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"skipLibCheck": true,
		"baseUrl": "./",
		"incremental": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true

	},
	"include": ["src", "dbtest", "prisma/generated"]
}
