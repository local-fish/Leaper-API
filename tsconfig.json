{
	"compilerOptions": {
		"lib": ["ESNext"],
    "rootDir": "./",

		"module": "esnext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"isolatedModules": true,

		"target": "esnext",
		"outDir": "./dist",
		"declaration": true,
		"removeComments": true,
		"sourceMap": true,
		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"skipLibCheck": true,
		"baseUrl": "./",
		"incremental": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,

		"paths": {
			"#prisma/*": ["./prisma/generated/*"],
			"#*": ["./src/*"],
      "#common/*": ["./src/common/*"],
		}
	},
	"include": ["src", "dbtest", "prisma/generated"]
}
