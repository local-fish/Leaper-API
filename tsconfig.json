{
	"compilerOptions": {
		"lib": ["ESNext"],

    "rootDirs": ["src", "prisma"],
		"module": "commonjs",
		"moduleResolution": "node",

		"allowSyntheticDefaultImports": true,

		"target": "esnext",
		"outDir": "./dist",
		"declaration": true,
		"removeComments": true,
		"sourceMap": true,
		"emitDecoratorMetadata": true,

		"experimentalDecorators": true,

		"skipLibCheck": true,
		"incremental": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true

	},

	"include": ["src", "prisma/generated"]
}
