generator client {
	provider = "prisma-client"
	output   = "./generated"

	moduleFormat = "cjs"
}

datasource db {
	provider = "postgresql"
}

model User {
	id Int @id @default(autoincrement())
	name String
	email String @unique
	role String
	pwhash Bytes 

	courses Course[] @relation(name: "users")
	coursesStudent Course[] @relation(name: "students")
	coursesLecturings Course[] @relation(name: "lecturers")
	courseGrades CourseGrade[]
	forums Forum[]
	forumComments ForumComment[]
	assessmentGrades AssessmentGrade[]
	assessmentSubmissions AssessmentSubmission[]
	files File[]
}

model Course {
	id Int @id @default(autoincrement())
	name String

	users User[] @relation(name: "users")
	students User[] @relation(name: "students")
	lecturers User[] @relation(name: "lecturers")
	sessions CourseSession[]
	gradesComp CourseGradeComp[]
	forums Forum[]
	assessments Assessment[]
}

model CourseSession {
	id Int @id @default(autoincrement())
	courseId Int
	topic String
	sessionNo Int
	startTime DateTime
	endTime DateTime
	location String

	files File[]
	course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

	@@index([startTime, endTime])
}

model CourseGradeComp {
	id Int @id @default(autoincrement())
	name String
	courseId Int

	grades CourseGrade[]
	course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseGrade {
	id Int @id @default(autoincrement())
	compid Int
	userId Int
	grade Int

	comp CourseGradeComp @relation(fields: [compid], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Forum {
	id Int @id @default(autoincrement())
	title String
	userId Int
	courseId Int
	time DateTime
	body String @db.VarChar(4000)

	comments ForumComment[]
	course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForumComment {
	id Int @id @default(autoincrement())
	forumId Int
	parentId Int?
	userId Int
	time DateTime
	body String @db.VarChar(4000)

	replies ForumComment[] @relation(name: "parent")

	parent ForumComment? @relation(name: "parent", fields: [parentId], references: [id], onDelete: Cascade)
	forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model File {
	id String @id
	name String
	userId Int
	size Int
	gcCluster Int

	owner User @relation(fields: [userId], references: [id], onDelete: Cascade)

	courseSessions CourseSession[]

	@@index([gcCluster])
}

model Assessment {
	id Int @id @default(autoincrement())
	courseId Int
	title String
	startDate DateTime?
	endDate DateTime?
	instruction String @db.VarChar(4000)

	course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

	grades AssessmentGrade[]
	questions AssessmentQuesiton[]
	submissions AssessmentSubmission[]
}

model AssessmentGrade {
	id Int @id @default(autoincrement())
	assessmentId Int
	userId Int
	grade Float

	assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssessmentQuesiton {
	id Int @id @default(autoincrement())
	assessmentId Int
	revision Int
	data Bytes

	assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

	submissions AssessmentSubmission[]

	@@index([revision])
}

model AssessmentSubmission {
	id Int @id @default(autoincrement())
	assessmentId Int
	questionId Int
	userId Int
	data Bytes
	grade Float?
	submitted Boolean? @default(false)

	assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
	question AssessmentQuesiton @relation(fields: [questionId], references: [id], onDelete: Cascade)
	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
