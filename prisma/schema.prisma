generator client {
	provider = "prisma-client"
	output   = "./generated"
}

datasource db {
	provider = "mysql"
}

model User {
	id Int @id @default(autoincrement())
	name String @unique
	email String
	role String
	pwhash Bytes @db.Binary(32)

	courses Course[]
	courseGrades CourseGrade[]
	forums Forum[]
	forumComments ForumComment[]
}

model Course {
	id Int @id @default(autoincrement())
	name String

	users User[]
	sessions CourseSession[]
	gradesComp CourseGradeComp[]
	forums Forum[]
}

model CourseSession {
	id Int @id @default(autoincrement())
	courseId Int
	topic String
	sessionNo Int
	startTime DateTime
	endTime DateTime
	location String

	files File[]
	course Course @relation(fields: [courseId], references: [id])

	@@index([startTime, endTime])
}

model CourseGradeComp {
	id Int @id @default(autoincrement())
	name String
	courseId Int

	grades CourseGrade[]
	course Course @relation(fields: [courseId], references: [id])
}

model CourseGrade {
	id Int @id @default(autoincrement())
	compid Int
	userId Int
	grade Int

	comp CourseGradeComp @relation(fields: [compid], references: [id])
	user User @relation(fields: [userId], references: [id])
}

model Forum {
	id Int @id @default(autoincrement())
	title String
	userId Int
	courseId Int
	time DateTime
	body String @db.VarChar(4000)

	comments ForumComment[]
	course Course @relation(fields: [courseId], references: [id])
	user User @relation(fields: [userId], references: [id])
}

model ForumComment {
	id Int @id @default(autoincrement())
	forumId Int
	parentId Int?
	userId Int
	time DateTime
	body String @db.VarChar(4000)

	replies ForumComment[] @relation(name: "parent")

	parent ForumComment? @relation(name: "parent", fields: [parentId], references: [id])
	forum Forum @relation(fields: [forumId], references: [id])
	user User @relation(fields: [userId], references: [id])
}

model File {
	hash Bytes @db.Binary(32) @id
	name String
	size Int

	courseSessions CourseSession[]
}
